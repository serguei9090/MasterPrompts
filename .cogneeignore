# Cognee and Cache
.cognee/
.fastembed_cache/
.cogneeignore

# Environments and Dependencies (Global)
**/node_modules/
.agents/skills/**/node_modules/
**/.venv/
**/__pycache__/
**/.pytest_cache/

# Tool Metadata
.beads/
.dolt/
.codanna/
.codex/
.vscode/

# Git
.git/

# Build and Transient Noise
dist/
build/
scratch/
morphic_**.tar.gz
*.pyc
.env
.env.example

# --- Morphic Framework Governance ---
# Index the 'Laws' and 'Actors', but ignore volatile tracking and tool noise.
docs/track/      # Volatile (Beads handle this)
.agents/skills/  # Tool implementation noise
!.agents/rules/
!.agents/workflows/
!.gemini/agents/

# Media and Heavy Assets (Excluded)
*.mp3
*.wav
*.aac
*.m4a
*.flac
*.mp4
*.mov
*.avi
*.ico
*.png
*.jpg
*.jpeg
*.webp
# Note: *.svg is ALLOWED as it is text-based XML and indexable by text models.
